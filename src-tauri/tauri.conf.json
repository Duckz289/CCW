{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Cache Warden",
  "version": "0.1.0",
  "identifier": "dev.local.claude-cache-warden",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Cache Warden",
        "width": 1180,
        "height": 780,
        "minWidth": 920,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
